# Used by the Ask paper tab. Never expose this value to the browser.
# Optional for local providers that do not require authentication.
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_MODEL=<YOUR_OPENAI_MODEL>
# Base URL for any OpenAI-compatible provider. Do not include /chat/completions.
OPENAI_BASE_URL=<YOUR_OPENAI_BASE_URL>
